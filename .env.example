# Copy this file to .env and fill in real values before running Jimothy
# anywhere but your own machine. .env is gitignored — never commit it.
#
# Generate a real secret key:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-to-a-real-random-secret-key

# True for local development, False for anything else.
DJANGO_DEBUG=True

# Comma-separated hostnames, required when DJANGO_DEBUG=False. Empty is
# fine for local-only (127.0.0.1/localhost always work in DEBUG mode).
DJANGO_ALLOWED_HOSTS=

# IANA timezone (e.g. America/Denver) -- calendar sync's workday-hours math
# runs in this timezone. Defaults to UTC, which is wrong for the meeting-
# hours calculation unless you're actually in UTC.
# DJANGO_TIME_ZONE=

# Calendar sync (Settings page "Connect Outlook"/"Connect Google") ships
# with True Ascent Labs LLC's own shared OAuth client IDs baked in, so these
# only need setting if you're running your own Azure/Google app
# registration instead -- see USER_GUIDE.md's "Connecting your calendar".
# JIMOTHY_GRAPH_CLIENT_ID=
# JIMOTHY_GOOGLE_CLIENT_ID=
# JIMOTHY_GOOGLE_CLIENT_SECRET=
