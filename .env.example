# Copy this file to .env and fill in real values before running Jimothy
# anywhere but your own machine. .env is gitignored — never commit it.
#
# Generate a real secret key:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-to-a-real-random-secret-key

# True for local development, False for anything else.
DJANGO_DEBUG=True

# Comma-separated hostnames, required when DJANGO_DEBUG=False. Empty is
# fine for local-only (127.0.0.1/localhost always work in DEBUG mode).
DJANGO_ALLOWED_HOSTS=
